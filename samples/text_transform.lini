// text-transform (SPEC §10): a live CSS property — uppercase / lowercase /
// capitalize. Browser-rendered (resvg ignores it). Set it on an element, a
// class, or — like font-size — globally to transform the whole scene.

{
  layout: column; gap: 14;
  text-transform: capitalize;
}

|box| "each word here capitalized"
|box| { text-transform: uppercase } "shout this"
|box| { text-transform: lowercase } "QUIET NOW"
