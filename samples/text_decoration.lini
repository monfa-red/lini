// text-decoration (SPEC §10): a live CSS property — underline / overline /
// line-through. Set it on an element, a class, or globally (states on .lini).

{
  layout: column; gap: 14;
}

|box| { text-decoration: underline } "underline"
|box| { text-decoration: line-through } "line-through"
|box| { text-decoration: overline } "overline"
