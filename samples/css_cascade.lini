// CSS cascade showcase: type defaults, styles, inline overrides, per-group
// text attrs, |wire| defaults — paint rides class rules and style= diffs.
{
  |wire|  stroke:#666 thickness:1
  |rect|  fill:lightyellow
  .loud   stroke:red thickness:2
  .calm   stroke:teal
}

plain |rect| "Plain"
loud  |rect| "Loud" .loud
mix   |rect| "Mix" .calm fill:lavender
crew  |group| "Crew" text-size:10 font:serif {
  tiny |rect| "Tiny"
}
plain -> loud
loud --> mix .calm
