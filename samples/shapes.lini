// Defines and containers — the shape-composition vocabulary.

treat::box { radius: 5; }
nest::slant { fill: gray; }

|treat| "Treat"
|nest|  "Nest"

toolbox |group| {
  layout: row; gap: 10;
  |icon| "save"
  |icon| "copy"
}

den |group| {
  layout: column; gap: 8; padding: 12;
  |caption| { font-weight: bold; "Title" }
  "Content"
}
