// Visual modifiers on closed shapes: stroke-style, stack, shadow, rotate.

layout: row; gap: 24; padding: 24;

|box| { width: 80; height: 40; stroke-style: dashed; "dashed" }
|box| { width: 80; height: 40; stroke-style: dotted; "dotted" }
|box| { width: 80; height: 40; stack: 4; "stack" }
|box| { width: 80; height: 40; shadow: 2 2 4; "shadow" }
|box| { width: 80; height: 40; rotate: 15; "rotate" }
