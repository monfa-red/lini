// Visual modifiers on closed shapes: stroke-style, stack, shadow, rotate.

layout: row; gap: 24; padding: 24;

|box| "dashed" { width: 80; height: 40; stroke-style: dashed; }
|box| "dotted" { width: 80; height: 40; stroke-style: dotted; }
|box| "stack" { width: 80; height: 40; stack: 4; }
|box| "shadow" { width: 80; height: 40; shadow: 2 2 4; }
|box| "rotate" { width: 80; height: 40; rotate: 15; }
