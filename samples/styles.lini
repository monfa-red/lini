// Class rules — reusable visual bundles applied with .name.

.thin {
  stroke: #444; stroke-width: 1;
}
.bold {
  font-weight: bold;
}
.power {
  stroke: red; stroke-width: 2;
}
.warn {
  stroke: orange;
}
.ghost {
  opacity: 0.3;
}

a |rect| "thin" .thin
b |rect| "bold" .bold
c |rect| "power" .power
d |rect| "warn" .warn
e |rect| "ghost" .ghost
