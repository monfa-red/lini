// font-style (SPEC §10): a live CSS property — italic / oblique — that emits on
// the node and inherits to descendant text. Not layout (the box keeps its size)
// and no global default, so text is upright until set; host CSS can override it.

{
  layout: row; gap: 20;
}

|box| "normal"
|box| { font-style: italic } "italic"
group |group| { font-style: oblique } [
  |caption| "styled group"
  a |box| "inherits"
]
