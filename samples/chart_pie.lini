// Pie family: a full pie and a donut (hole: fraction).
|grid| { columns: repeat(2); gap: 24; } [
  |pie| "Traffic sources" [
    |slice| "Search" { value: 45; }
    |slice| "Direct" { value: 25; }
    |slice| "Social" { value: 18; }
    |slice| "Referral" { value: 12; }
  ]
  |pie| "Spend" { hole: 0.5; } [
    |slice| "Ads" { value: 40; }
    |slice| "SEO" { value: 30; }
    |slice| "Direct" { value: 30; }
  ]
]
