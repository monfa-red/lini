// text-shadow (SPEC §10): a live CSS property — offsets + blur + colour. lini's
// unitless numbers compile to px. Set it on an element, a class, or globally.
// Browser-rendered.

{
  layout: column; gap: 18;
}

|box| { text-shadow: 1 1 2 gray } "soft shadow"
|box| { text-shadow: 2 2 0 #ff6600 } "hard offset"
|box| { font-size: 24; text-shadow: 0 0 6 crimson } "glow"
