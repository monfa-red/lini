// margin: signed outer spacing on a child — grows or tightens the parent.

layout: row; gap: 40; padding: 20; align: start;

loose |group| "Default" {
  layout: column; gap: 24;
  a |box| "Row A"
  b |box| "Row B"
}

tight |group| {
  layout: column; gap: 24;
    |text| "Tight" { mount: in; margin: -6 0 -14 0; }
  a |box| "Row A"
  b |box| "Row B"
}

packed |group| "Packed" {
  layout: column; gap: 24;
  a |box| "Row A" { margin: 0 0 -16 0; }
  b |box| "Row B"
}
