{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lini",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "type_bars"
        },
        {
          "type": "SYMBOL",
          "name": "property"
        },
        {
          "type": "SYMBOL",
          "name": "assignment"
        },
        {
          "type": "SYMBOL",
          "name": "call"
        },
        {
          "type": "SYMBOL",
          "name": "group"
        },
        {
          "type": "SYMBOL",
          "name": "css_var"
        },
        {
          "type": "SYMBOL",
          "name": "class"
        },
        {
          "type": "SYMBOL",
          "name": "side"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "hex_color"
        },
        {
          "type": "SYMBOL",
          "name": "link_op"
        },
        {
          "type": "SYMBOL",
          "name": "fanout"
        },
        {
          "type": "SYMBOL",
          "name": "value_ident"
        },
        {
          "type": "SYMBOL",
          "name": "_punct"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape"
              },
              {
                "type": "PATTERN",
                "value": "[^\"\\\\\\n]+"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "escape": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "PATTERN",
            "value": "[\"\\\\nt]"
          }
        ]
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[-+]?(\\d+\\.\\d+|\\d+|\\.\\d+)"
      }
    },
    "hex_color": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "#([0-9a-fA-F]{8}|[0-9a-fA-F]{6}|[0-9a-fA-F]{4}|[0-9a-fA-F]{3})"
      }
    },
    "css_var": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "--[A-Za-z_][\\w-]*"
      }
    },
    "_ident": {
      "type": "PATTERN",
      "value": "[A-Za-z_][\\w-]*"
    },
    "id": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[A-Za-z_][\\w-]*"
          }
        ]
      }
    },
    "define_op": {
      "type": "STRING",
      "value": "::"
    },
    "type_bars": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "ALIAS",
                      "content": {
                        "type": "SYMBOL",
                        "name": "_ident"
                      },
                      "named": true,
                      "value": "type"
                    },
                    {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "SEQ",
                          "members": [
                            {
                              "type": "SYMBOL",
                              "name": "define_op"
                            },
                            {
                              "type": "SYMBOL",
                              "name": "_ident"
                            }
                          ]
                        },
                        {
                          "type": "BLANK"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "STRING",
                  "value": "-"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "id"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "|"
        }
      ]
    },
    "property": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "_ident"
            },
            "named": true,
            "value": "property"
          }
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": ":"
          }
        }
      ]
    },
    "assign_op": {
      "type": "STRING",
      "value": "="
    },
    "params": {
      "type": "SEQ",
      "members": [
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "("
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_expr_item"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "assignment": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "_ident"
            },
            "named": true,
            "value": "value_ident"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "params"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "assign_op"
        }
      ]
    },
    "call": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_ident"
          },
          "named": true,
          "value": "call_name"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "("
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_expr_item"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_expr_item"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_expr_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "hex_color"
        },
        {
          "type": "SYMBOL",
          "name": "css_var"
        },
        {
          "type": "SYMBOL",
          "name": "call"
        },
        {
          "type": "SYMBOL",
          "name": "group"
        },
        {
          "type": "SYMBOL",
          "name": "side"
        },
        {
          "type": "SYMBOL",
          "name": "value_ident"
        },
        {
          "type": "SYMBOL",
          "name": "math_op"
        },
        {
          "type": "STRING",
          "value": ","
        }
      ]
    },
    "math_op": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[-+*/%^<>=!?:~]+"
      }
    },
    "class": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(\\.[A-Za-z_][\\w-]*)+"
      }
    },
    "side": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "PATTERN",
            "value": "[A-Za-z_][\\w-]*"
          }
        ]
      }
    },
    "link_op": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[<>*o+]*(---|--|-|~|\\|\\|)[<>*o+]*"
      }
    },
    "fanout": {
      "type": "STRING",
      "value": "&"
    },
    "value_ident": {
      "type": "ALIAS",
      "content": {
        "type": "SYMBOL",
        "name": "_ident"
      },
      "named": true,
      "value": "value_ident"
    },
    "_punct": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "STRING",
          "value": "}"
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "STRING",
          "value": "]"
        },
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "STRING",
          "value": ","
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\n]"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}