    .lini .lini-sequence-message { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 13px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
