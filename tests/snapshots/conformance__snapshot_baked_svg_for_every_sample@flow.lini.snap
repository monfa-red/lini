<svg xmlns="http://www.w3.org/2000/svg" viewBox="-150 -202.5 300 405" width="300" height="405" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-red { fill: #fde9e6; stroke: #af3d34; color: #af3d34; }
    .lini .lini-sky { fill: #dff2f9; stroke: #0079a6; color: #0079a6; }
    .lini .lini-teal { fill: #dff4f1; stroke: #008279; color: #008279; }
    .lini .lini-purple { fill: #ecedfe; stroke: #6356be; color: #6356be; }
    .lini .lini-orange { fill: #fbebe1; stroke: #a74a00; color: #a74a00; }
    .lini .lini-wire { fill: none; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-wire-dashed { stroke-dasharray: 8,8; }
    .lini .lini-wire-dotted { stroke-dasharray: 2,4; }
    .lini .lini-wire-label { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 11px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-style-solid { stroke: #e98477; }
    .lini .lini-style-solid .lini-marker { fill: #e98477; }
    .lini .lini-style-dashed { stroke: #21b6dd; }
    .lini .lini-style-dashed .lini-marker { fill: #21b6dd; }
    .lini .lini-style-dotted { stroke: #00beb3; }
    .lini .lini-style-dotted .lini-marker { fill: #00beb3; }
    .lini .lini-style-wavy { stroke: #9c97f4; }
    .lini .lini-style-wavy .lini-marker { fill: #9c97f4; }
    .lini .lini-style-thick { stroke: #e18e51; stroke-width: 3; }
    .lini .lini-style-thick .lini-marker { fill: #e18e51; }
  </style>
