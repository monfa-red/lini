---
source: tests/conformance.rs
expression: svg
input_file: samples/font_style.lini
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="-213.5 -86.5 427 155.5" width="427" height="155.5" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: bold; color: black; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-plain { fill: none; stroke: none; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,4; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-box" transform="translate(-145.5,0)">
      <rect x="-47" y="-27.5" width="94" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">normal</text>
    </g>
    <g class="lini-node lini-box" style="font-style: italic" transform="translate(-29.5,0)">
      <rect x="-47" y="-27.5" width="94" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">italic</text>
    </g>
    <g class="lini-node lini-group lini-box" data-id="group" style="font-style: oblique" transform="translate(116,0)">
      <rect x="-77" y="-48.5" width="154" height="97" rx="6" ry="6"/>
      <g class="lini-node lini-box" data-id="a" transform="translate(0,0)">
        <rect x="-56" y="-27.5" width="112" height="55" rx="6" ry="6"/>
        <text class="lini-text" x="0" y="0">inherits</text>
      </g>
      <g class="lini-node lini-caption lini-plain lini-box" transform="translate(-32.8,-59.5)">
        <rect x="-43.2" y="-6" width="86.4" height="12" rx="6" ry="6"/>
        <text class="lini-text" x="0" y="0">styled group</text>
      </g>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
