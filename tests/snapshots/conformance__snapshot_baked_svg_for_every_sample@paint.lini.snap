    .lini .lini-badge { fill: #0a84ff; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-card { stroke: none; color: white; }
    .lini .lini-link { fill: none; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-link-label { fill: currentColor; stroke: none; text-anchor: middle; font-size: 11px; font-weight: 400; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
