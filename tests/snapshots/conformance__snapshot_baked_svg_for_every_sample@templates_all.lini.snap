<svg xmlns="http://www.w3.org/2000/svg" viewBox="-174.5 -217.5 349 417.5" width="349" height="417.5" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: bold; color: black; }
    .lini .lini-shape-box { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-shape-plain { fill: none; stroke: none; }
    .lini .lini-shape-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,4; }
    .lini .lini-shape-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-shape-badge { fill: #0a84ff; stroke: none; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-shape-note { fill: #fff9c4; stroke: none; }
    .lini .lini-shape-table { fill: none; stroke: #444; font-size: 14px; font-weight: normal; stroke-dasharray: none; }
  </style>
