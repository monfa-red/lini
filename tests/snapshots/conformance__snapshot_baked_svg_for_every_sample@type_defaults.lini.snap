<svg xmlns="http://www.w3.org/2000/svg" viewBox="-162.5 -48.5 325 97" width="325" height="97" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: bold; color: black; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-alert { stroke: red; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-box" data-id="cat" transform="translate(-108,0)">
      <rect x="-33.5" y="-27.5" width="67" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">Cat</text>
    </g>
    <g class="lini-node lini-box" data-id="dog" transform="translate(-9,0)">
      <rect x="-33.5" y="-27.5" width="67" height="55" rx="0" ry="0"/>
      <text class="lini-text" x="0" y="0">Dog</text>
    </g>
    <g class="lini-node lini-alert lini-oval" data-id="mouse" transform="translate(99,0)">
      <ellipse cx="0" cy="0" rx="42.5" ry="27.5"/>
      <text class="lini-text" x="0" y="0">Mouse</text>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
