<svg xmlns="http://www.w3.org/2000/svg" viewBox="-222 -153 444 306" width="444" height="306" class="lini">
  <style>
    .lini { font-family: sans-serif; font-size: 13px; color: black; }
    .lini .lini-shape-rect { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-oval { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-hex { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-slant { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-cyl { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-diamond { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-cloud { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-poly { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-path { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-line { fill: none; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-shape-icon { fill: #444; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-shape-rect" transform="translate(-161.5,-102.5)">
