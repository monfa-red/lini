<svg xmlns="http://www.w3.org/2000/svg" viewBox="-216.5 -277.5 462.2 555" width="462.2" height="555" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-cyl { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-icon { fill: rgba(0, 0, 0, 0.16); stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,3; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-badge { fill: #0a84ff; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-sign { stroke-width: 2; }
    .lini .lini-edge { fill: #cff6ff; stroke: #00547e; color: #00547e; }
    .lini .lini-svc { fill: #cdf9f4; stroke: #005d56; color: #005d56; }
    .lini .lini-api { fill: #d6f8e3; stroke: #005d26; color: #005d26; }
    .lini .lini-auth { fill: #eaebff; stroke: #443394; color: #443394; }
    .lini .lini-store { fill: #ffe3ec; stroke: #811442; color: #811442; }
    .lini .lini-link { fill: none; stroke: #747474; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-link-dashed { stroke-dasharray: 6,4.5; }
    .lini .lini-link-label { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 11px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-style-flow { stroke: #2774ce; }
    .lini .lini-style-flow .lini-marker { fill: #2774ce; }
    .lini .lini-style-cache { stroke: #008e85; }
    .lini .lini-style-cache .lini-marker { fill: #008e85; }
    .lini .lini-style-async { stroke: #9f6900; }
    .lini .lini-style-async .lini-marker { fill: #9f6900; }
    .lini .lini-style-auth { stroke: #6e62cc; }
    .lini .lini-style-auth .lini-marker { fill: #6e62cc; }
  </style>
