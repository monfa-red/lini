<svg xmlns="http://www.w3.org/2000/svg" viewBox="-260.5 -287 534.2 574" width="534.2" height="574" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-cyl { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-plain { fill: none; stroke: none; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,4; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-badge { fill: #0a84ff; stroke: none; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-edge { fill: #dff2f9; stroke: #0079a6; color: #0079a6; }
    .lini .lini-svc { fill: #dff4f1; stroke: #008279; color: #008279; }
    .lini .lini-store { fill: #fde9ec; stroke: #ac3a5c; color: #ac3a5c; }
    .lini .lini-wire { fill: none; stroke: #696969; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-wire-dashed { stroke-dasharray: 8,8; }
    .lini .lini-wire-label { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 11px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-style-flow { stroke: #9c97f4; stroke-width: 3.5; }
    .lini .lini-style-flow .lini-marker { fill: #9c97f4; }
    .lini .lini-style-cache { stroke: #00beb3; }
    .lini .lini-style-cache .lini-marker { fill: #00beb3; }
    .lini .lini-style-async { stroke: #e18e51; }
    .lini .lini-style-async .lini-marker { fill: #e18e51; }
