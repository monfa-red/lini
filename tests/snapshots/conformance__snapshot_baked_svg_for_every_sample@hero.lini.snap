<svg xmlns="http://www.w3.org/2000/svg" viewBox="-260.5 -287 534.2 574" width="534.2" height="574" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-hex { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-cyl { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,4; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-badge { fill: #0a84ff; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-edge { fill: #c0f5ff; stroke: #005580; color: #005580; }
    .lini .lini-svc { fill: #bef9f3; stroke: #005e57; color: #005e57; }
    .lini .lini-auth { fill: #e6e6ff; stroke: #443297; color: #443297; }
    .lini .lini-store { fill: #ffdbe8; stroke: #821041; color: #821041; }
    .lini .lini-link { fill: none; stroke: #9e9e9e; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-link-dashed { stroke-dasharray: 8,8; }
    .lini .lini-link-label { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 11px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-style-flow { stroke: #54a0fe; }
    .lini .lini-style-flow .lini-marker { fill: #54a0fe; }
    .lini .lini-style-cache { stroke: #00bbb0; }
    .lini .lini-style-cache .lini-marker { fill: #00bbb0; }
    .lini .lini-style-async { stroke: #e38231; }
    .lini .lini-style-async .lini-marker { fill: #e38231; }
    .lini .lini-style-auth { stroke: #968efb; }
    .lini .lini-style-auth .lini-marker { fill: #968efb; }
