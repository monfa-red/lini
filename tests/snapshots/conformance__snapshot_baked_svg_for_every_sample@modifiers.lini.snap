<svg xmlns="http://www.w3.org/2000/svg" viewBox="-270.5 -40.5 541 81" width="541" height="81" class="lini">
  <style>
    .lini { font-family: sans-serif; font-size: 14px; color: black; }
    .lini .lini-shape-box { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
  </style>
  <defs>
    <filter id="lini-shadow-1" x="-50%" y="-50%" width="200%" height="200%"><feDropShadow dx="2" dy="2" stdDeviation="4" flood-color="rgba(0, 0, 0, 0.2)"/></filter>
  </defs>
  <g class="lini-scene">
    <g class="lini-node lini-shape-box" style="stroke-dasharray: 4,4" transform="translate(-210,0)">
      <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
        <text x="0" y="0">dashed</text>
      </g>
    </g>
    <g class="lini-node lini-shape-box" style="stroke-dasharray: 1,3" transform="translate(-105,0)">
      <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
        <text x="0" y="0">dotted</text>
      </g>
    </g>
    <g class="lini-node lini-shape-box" transform="translate(0,0)">
      <g transform="translate(4,-4)">
        <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      </g>
      <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
        <text x="0" y="0">stack</text>
      </g>
    </g>
    <g class="lini-node lini-shape-box" transform="translate(105,0)">
      <g filter="url(#lini-shadow-1)">
        <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      </g>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
        <text x="0" y="0">shadow</text>
      </g>
    </g>
    <g class="lini-node lini-shape-box" transform="translate(210,0) rotate(15)">
      <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
        <text x="0" y="0">rotate</text>
      </g>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
