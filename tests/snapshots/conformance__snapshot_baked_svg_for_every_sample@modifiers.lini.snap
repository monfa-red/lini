<svg xmlns="http://www.w3.org/2000/svg" viewBox="-270.5 -40.5 541 81" width="541" height="81" class="lini">
  <style>
    .lini { font-family: sans-serif; font-size: 13px; color: black; }
    .lini .lini-shape-rect { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-shape-rect" style="stroke-dasharray: 4,4" transform="translate(-210,0)">
      <rect x="-40" y="-20" width="80" height="40" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
