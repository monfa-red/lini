    .lini .lini-magnifier { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; }
    .lini .lini-page { fill: white; stroke-width: 0; }
    .lini .lini-frame { fill: none; stroke: #444; stroke-width: 2; }
    .lini .lini-zone { color: rgba(0, 0, 0, 0.545); font-size: 9px; }
