---
source: tests/conformance.rs
expression: svg
input_file: samples/drawing_assembly.lini
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="-59 -44 168 88" width="168" height="88" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-line { fill: none; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; }
    .lini .lini-hole { fill: white; stroke: #444; }
    .lini .lini-centerline { fill: none; stroke-width: 1; stroke-dasharray: 10,3,1,3; }
  </style>
  <defs/>
  <rect class="lini-canvas" x="-59" y="-44" width="168" height="88"/>
  <g class="lini-scene">
    <g class="lini-node lini-drawing lini-block" data-id="motor" transform="translate(0,0)">
      <rect x="-38" y="-21" width="76" height="42" rx="0" ry="0"/>
      <g class="lini-node lini-rect lini-box lini-block" data-id="frame" transform="translate(-12,0)">
        <rect x="-25" y="-20" width="50" height="40" rx="0" ry="0"/>
      </g>
      <g class="lini-node lini-rect lini-box lini-block" data-id="shaft" transform="translate(25,0)">
        <rect x="-12" y="-4" width="24" height="8" rx="0" ry="0"/>
      </g>
    </g>
    <g class="lini-node lini-drawing lini-block" data-id="pump" transform="translate(65,0)">
      <rect x="-23" y="-23" width="46" height="46" rx="0" ry="0"/>
      <g class="lini-node lini-oval" data-id="casing" transform="translate(0,0)">
        <ellipse cx="0" cy="0" rx="22" ry="22"/>
      </g>
      <g class="lini-node lini-hole lini-oval" data-id="gland" transform="translate(0,0)">
        <ellipse cx="0" cy="0" rx="5" ry="5"/>
        <g class="lini-node lini-centerline lini-line" transform="translate(0,0)">
          <line x1="-9" y1="0" x2="9" y2="0"/>
        </g>
        <g class="lini-node lini-centerline lini-line" transform="translate(0,0)">
          <line x1="0" y1="9" x2="0" y2="-9"/>
        </g>
      </g>
    </g>
  </g>
  <g class="lini-links"/>
</svg>
