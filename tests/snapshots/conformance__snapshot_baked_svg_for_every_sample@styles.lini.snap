<svg xmlns="http://www.w3.org/2000/svg" viewBox="-447.7975 -288.75 895.595 577.5" width="895.595" height="577.5" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: #cdf9f4; stroke: #005d56; stroke-width: 2; color: #005d56; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-box { fill: #cff6ff; stroke: #00547e; stroke-width: 2; color: #00547e; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,3; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-alert { fill: #ffe4df; stroke: #ef675e; color: #851618; }
    .lini .lini-style-thin { stroke-width: 1; }
    .lini .lini-style-bold { font-weight: bold; }
    .lini .lini-style-power { stroke: #ef675e; stroke-width: 2.5; }
    .lini .lini-style-warn { stroke: #e47600; stroke-width: 2; }
    .lini .lini-style-ghost { opacity: 0.35; }
  </style>
