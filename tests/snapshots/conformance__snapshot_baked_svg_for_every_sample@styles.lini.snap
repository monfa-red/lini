    .lini .lini-alert { fill: #ffe4df; stroke: #ef675e; color: #851618; }
    .lini .lini-style-thin { stroke-width: 1; }
    .lini .lini-style-bold { font-weight: bold; }
    .lini .lini-style-power { stroke: #ef675e; stroke-width: 2.5; }
    .lini .lini-style-warn { stroke: #e47600; stroke-width: 2; }
    .lini .lini-style-ghost { opacity: 0.35; }
