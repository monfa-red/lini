    <g class="lini-node lini-shape-rect lini-style-warn" data-id="d" transform="translate(0,67.5)">
      <rect x="-31.4" y="-23" width="62.8" height="46" rx="0" ry="0"/>
      <g class="lini-node lini-shape-text" transform="translate(0,0)">
