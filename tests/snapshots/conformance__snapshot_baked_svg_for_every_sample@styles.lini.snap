<svg xmlns="http://www.w3.org/2000/svg" viewBox="-455.5 -288.75 911 577.5" width="911" height="577.5" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-box { fill: #dff2f9; stroke: #0079a6; stroke-width: 2; color: #0079a6; stroke-dasharray: none; }
    .lini .lini-oval { fill: #dff4f1; stroke: #008279; stroke-width: 2; color: #008279; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-plain { fill: none; stroke: none; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,4; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-alert { fill: #fde9e6; stroke: #e98477; color: #af3d34; }
    .lini .lini-style-thin { stroke-width: 1; }
    .lini .lini-style-bold { font-weight: bold; }
    .lini .lini-style-power { stroke: #e98477; stroke-width: 2.5; }
    .lini .lini-style-warn { stroke: #e18e51; stroke-width: 2; }
    .lini .lini-style-ghost { opacity: 0.35; }
  </style>
  <defs>
