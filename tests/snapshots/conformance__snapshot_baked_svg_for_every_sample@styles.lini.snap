<svg xmlns="http://www.w3.org/2000/svg" viewBox="-56.25 -178 112.5 356" width="112.5" height="356" class="lini">
  <style>
    .lini { font-family: sans-serif; font-size: 14px; color: black; }
    .lini .lini-shape-rect { fill: white; stroke: #444; stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-shape-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-style-thin { stroke: #444; stroke-width: 1; }
    .lini .lini-style-bold { font-weight: bold; }
    .lini .lini-style-power { stroke: red; stroke-width: 2; }
    .lini .lini-style-warn { stroke: orange; }
    .lini .lini-style-ghost { opacity: 0.3; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-shape-rect lini-style-thin" data-id="a" transform="translate(0,-134.5)">
