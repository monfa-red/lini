    .lini .lini-footnote { color: rgba(0, 0, 0, 0.5); font-size: 12px; }
    .lini .lini-badge { fill: #0a84ff; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-table { fill: none; stroke: #444; stroke-width: 2; font-size: 14px; font-weight: normal; stroke-dasharray: none; }
    .lini .lini-header { fill: rgba(0, 0, 0, 0.06); font-weight: 600; }
    .lini .lini-panel { fill: #eeeeee; stroke: #cecece; }
    .lini .lini-tile { fill: #7eddfd; stroke: #00547e; color: #00547e; }
  </style>
