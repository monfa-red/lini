<svg xmlns="http://www.w3.org/2000/svg" viewBox="-276.75 -176.75 553.5 353.5" width="553.5" height="353.5" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 1.5; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 1.5; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,3; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: normal; }
    .lini .lini-footnote { color: rgba(0, 0, 0, 0.5); font-size: 11px; }
    .lini .lini-badge { fill: #0a84ff; color: white; font-size: 11px; font-weight: normal; }
    .lini .lini-table { fill: none; stroke: #444; font-size: 14px; font-weight: normal; stroke-dasharray: none; }
    .lini .lini-header { fill: rgba(0, 0, 0, 0.06); font-weight: bold; }
    .lini .lini-panel { fill: #eeeeee; stroke: #cecece; }
    .lini .lini-tile { fill: #7eddfd; stroke: #00547e; color: #00547e; }
