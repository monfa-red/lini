<svg xmlns="http://www.w3.org/2000/svg" viewBox="-594 -420 1188 840" width="297mm" height="210mm" class="lini">
  <style>
    .lini { font-family: "Google Sans Code", ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: 500; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-oval { fill: white; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-poly { stroke-dasharray: none; }
    .lini .lini-sketch { fill: white; stroke: black; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-line { fill: none; stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-dim-line { fill: none; stroke: black; stroke-width: 1; }
    .lini .lini-ext-line { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; }
    .lini .lini-dim-text { font-size: 12px; font-weight: normal; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-halo { stroke: black; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; }
    .lini .lini-caption { color: rgba(0, 0, 0, 0.5); font-size: 12px; font-weight: 400; }
    .lini .lini-footnote { color: rgba(0, 0, 0, 0.5); font-size: 12px; }
    .lini .lini-hole { fill: white; stroke: black; }
    .lini .lini-centerline { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; stroke-dasharray: 10,3,1,3; }
    .lini .lini-pitch-circle { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; stroke-dasharray: 10,3,1,3; }
    .lini .lini-shoulder { stroke: black; }
    .lini .lini-threadline { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; }
    .lini .lini-plane { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; stroke-dasharray: 10,3,1,3; }
    .lini .lini-magnifier { fill: none; stroke: rgba(0, 0, 0, 0.545); stroke-width: 1; }
    .lini .lini-page { fill: white; stroke-width: 0; }
    .lini .lini-frame { fill: none; stroke: #444; stroke-width: 2; }
    .lini .lini-zone { color: rgba(0, 0, 0, 0.545); font-size: 9px; }
    .lini .lini-tick { fill: none; stroke: #444; stroke-width: 1; }
    .lini .lini-steel { fill: url(#lini-hatch-1); }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-marker-dim { fill: black; }
  </style>
