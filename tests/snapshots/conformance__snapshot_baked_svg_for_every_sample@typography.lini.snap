    </g>
    <g class="lini-node lini-box" style="text-decoration: underline" transform="translate(0,52.5)">
      <rect x="-65" y="-27.5" width="130" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">underlined</text>
    </g>
    <g class="lini-node lini-box" style="text-shadow: 1px 1px 2px gray" transform="translate(0,121.5)">
