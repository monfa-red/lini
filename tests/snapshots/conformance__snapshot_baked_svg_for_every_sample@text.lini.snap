<svg xmlns="http://www.w3.org/2000/svg" viewBox="-212 -140.5 424 281" width="424" height="281" class="lini">
  <style>
    .lini { font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: bold; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
    .lini .lini-box { fill: white; stroke: #444; stroke-width: 2; }
    .lini .lini-link { fill: none; stroke: #9e9e9e; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-link-label { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; font-size: 11px; font-weight: normal; }
    .lini .lini-cut-bg { fill: white; stroke: none; }
    .lini .lini-cut { fill: black; stroke: none; }
    .lini .lini-marker { fill: #444; stroke: none; }
  </style>
  <defs/>
  <rect class="lini-canvas" x="-212" y="-140.5" width="424" height="281"/>
  <g class="lini-scene">
    <text class="lini-text" x="0" y="-104.5" style="font-weight: bold; font-size: 20px">Styleable text, in place</text>
    <g class="lini-node lini-row lini-block" data-id="styles" transform="translate(0,-60)">
      <rect x="-185" y="-7.5" width="370" height="15" rx="0" ry="0"/>
      <text class="lini-text" x="-153.5" y="0">default</text>
      <text class="lini-text" x="-70" y="0" style="fill: #851618">coloured</text>
      <text class="lini-text" x="0" y="0" style="font-weight: bold">bold</text>
      <text class="lini-text" x="61" y="0" style="font-style: italic">italic</text>
      <text class="lini-text" x="144.5" y="0" style="text-decoration: underline">underline</text>
    </g>
    <g class="lini-node lini-box lini-block" data-id="a" transform="translate(0,3)">
      <rect x="-42.5" y="-27.5" width="85" height="55" rx="8" ry="8"/>
      <text class="lini-text" x="0" y="0">Alpha</text>
    </g>
    <g class="lini-node lini-box lini-block" data-id="b" transform="translate(0,86)">
      <rect x="-38" y="-27.5" width="76" height="55" rx="8" ry="8"/>
      <text class="lini-text" x="0" y="0">Beta</text>
    </g>
  </g>
  <g class="lini-links">
    <g class="lini-link" style="font-size: 11" data-from="a" data-to="b">
      <mask id="lini-label-cut-0" maskUnits="userSpaceOnUse" x="37" y="1" width="95.75" height="87"><rect class="lini-cut-bg" x="37" y="1" width="95.75" height="87"/><rect class="lini-cut" x="77.95" y="29.6" width="105.6" height="14.3"/></mask>
      <path d="M 43.5 3 L 114.75 3 A 16 16 0 0 1 130.75 19 L 130.75 70 A 16 16 0 0 1 114.75 86 L 42.5 86" mask="url(#lini-label-cut-0)"/>
