    .lini .lini-style-sky { fill: #cff6ff; stroke: #00547e; color: #00547e; }
    .lini .lini-style-sky .lini-marker { fill: #00547e; }
    .lini .lini-style-purple { fill: #eaebff; stroke: #443394; color: #443394; }
