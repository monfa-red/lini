<svg xmlns="http://www.w3.org/2000/svg" viewBox="-278.1 -217 556.2 442" width="556.2" height="442" class="lini">
  <style>
    .lini { font-family: "Google Sans Code", ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; font-size: 15px; font-weight: normal; color: black; }
    .lini .lini-canvas { fill: white; }
    .lini .lini-block { fill: none; stroke: none; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; }
    .lini .lini-icon { fill: rgba(0, 0, 0, 0.16); stroke: #444; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-group { fill: rgba(0, 0, 0, 0.03); stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; stroke-dasharray: 4,3; }
    .lini .lini-sign { stroke-width: 2; font-size: 12px; }
    .lini .lini-tile { font-size: 13px; }
    .lini .lini-lbl { color: #484848; font-size: 13px; font-weight: bold; }
    .lini .lini-cap { color: #747474; font-size: 11px; }
    .lini .lini-link { fill: none; stroke: #484848; stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-link-dashed { stroke-dasharray: 6,4.5; }
    .lini .lini-link-dotted { stroke-dasharray: 2,4; }
    .lini .lini-marker { fill: #444; stroke: none; }
    .lini .lini-style-rose { fill: #ffe3ec; stroke: #811442; color: #811442; }
    .lini .lini-style-rose .lini-marker { fill: #811442; }
    .lini .lini-style-amber { fill: #feedca; stroke: #6d3b00; color: #6d3b00; }
    .lini .lini-style-amber .lini-marker { fill: #6d3b00; }
    .lini .lini-style-teal { fill: #cdf9f4; stroke: #005d56; color: #005d56; }
    .lini .lini-style-teal .lini-marker { fill: #005d56; }
    .lini .lini-style-sky { fill: #cff6ff; stroke: #00547e; color: #00547e; }
    .lini .lini-style-sky .lini-marker { fill: #00547e; }
    .lini .lini-style-purple { fill: #eaebff; stroke: #443394; color: #443394; }
    .lini .lini-style-purple .lini-marker { fill: #443394; }
    .lini .lini-style-lime { fill: #e8f4d3; stroke: #385300; color: #385300; }
    .lini .lini-style-lime .lini-marker { fill: #385300; }
    .lini .lini-marker.lini-marker-open { fill: none; stroke: inherit; stroke-linecap: round; stroke-dasharray: none; }
  </style>
