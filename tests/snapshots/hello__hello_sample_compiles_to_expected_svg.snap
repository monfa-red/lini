<svg xmlns="http://www.w3.org/2000/svg" viewBox="-63.5 -48.5 127 97" width="127" height="97" class="lini">
  <style>
    @layer lini.defaults { :root, .lini { --lini-accent: #0a84ff;  --lini-airwire: crimson;  --lini-bg: white;  --lini-caption-color: rgba(0, 0, 0, 0.4);  --lini-caption-font-weight: normal;  --lini-danger: crimson;  --lini-fg: black;  --lini-fill: white;  --lini-font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace;  --lini-font-weight: bold;  --lini-group-fill: rgba(0, 0, 0, 0.03);  --lini-group-stroke: rgba(0, 0, 0, 0.4);  --lini-muted: #888;  --lini-note-bg: #fff9c4;  --lini-on-accent: white;  --lini-shadow: rgba(0, 0, 0, 0.2);  --lini-stroke: #444;  --lini-text-color: var(--lini-fg);  --lini-warn: orange;  --lini-wire-font-weight: normal; } }
    .lini { font-family: var(--lini-font-family); font-size: 15px; font-weight: var(--lini-font-weight); color: var(--lini-text-color); }
    .lini .lini-shape-box { fill: var(--lini-fill); stroke: var(--lini-stroke); stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-shape-box" transform="translate(0,0)">
      <rect x="-42.5" y="-27.5" width="85" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">hello</text>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
