---
source: tests/hello.rs
expression: svg
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="-63.5 -48.5 127 97" width="127" height="97" class="lini">
  <style>
    @layer lini.defaults {
      :root, .lini { color-scheme: light dark; --lini-accent: light-dark(#0a84ff, #4aa3ff); --lini-accent-text: white; --lini-airwire: light-dark(crimson, #ff6b6b); --lini-bg: light-dark(white, #1b1b1f); --lini-caption-color: light-dark(rgba(0, 0, 0, 0.5), rgba(255, 255, 255, 0.55)); --lini-caption-font-weight: normal; --lini-danger: light-dark(crimson, #ff6b6b); --lini-fg: light-dark(black, #e8e8ea); --lini-fill: light-dark(white, #26262b); --lini-font-family: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace; --lini-font-weight: bold; --lini-footer-color: light-dark(rgba(0, 0, 0, 0.5), rgba(255, 255, 255, 0.55)); --lini-group-fill: light-dark(rgba(0, 0, 0, 0.03), rgba(255, 255, 255, 0.05)); --lini-group-stroke: light-dark(rgba(0, 0, 0, 0.4), rgba(255, 255, 255, 0.4)); --lini-muted: light-dark(#888, #9aa0a6); --lini-note-bg: light-dark(#fff9c4, #4a4733); --lini-shadow-color: light-dark(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.5)); --lini-stroke: light-dark(#444, #9aa0a6); --lini-text-color: var(--lini-fg); --lini-warn: light-dark(orange, #ffb454); --lini-wire-font-weight: normal; }
      .lini[data-theme="dark"], [data-theme="dark"] .lini { color-scheme: dark; }
      .lini[data-theme="light"], [data-theme="light"] .lini { color-scheme: light; }
    }
    .lini { font-family: var(--lini-font-family); font-size: 15px; font-weight: var(--lini-font-weight); color: var(--lini-text-color); }
    .lini .lini-canvas { fill: var(--lini-bg); }
    .lini .lini-box { fill: var(--lini-fill); stroke: var(--lini-stroke); stroke-width: 2; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
  </style>
  <defs/>
  <rect class="lini-canvas" x="-63.5" y="-48.5" width="127" height="97"/>
  <g class="lini-scene">
    <g class="lini-node lini-box" transform="translate(0,0)">
      <rect x="-42.5" y="-27.5" width="85" height="55" rx="6" ry="6"/>
      <text class="lini-text" x="0" y="0">hello</text>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
