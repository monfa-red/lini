<svg xmlns="http://www.w3.org/2000/svg" viewBox="-55.75 -43.5 111.5 87" width="111.5" height="87" class="lini">
  <style>
    @layer lini.defaults { :root, .lini { --lini-accent: #0a84ff;  --lini-airwire: crimson;  --lini-bg: white;  --lini-danger: crimson;  --lini-fg: black;  --lini-fill: white;  --lini-font-family: sans-serif;  --lini-group-fill: rgba(0, 0, 0, 0.03);  --lini-group-stroke: #bbb;  --lini-muted: #888;  --lini-note-bg: #fff9c4;  --lini-on-accent: white;  --lini-shadow: rgba(0, 0, 0, 0.2);  --lini-stroke: #444;  --lini-text-color: var(--lini-fg);  --lini-warn: orange; } }
    .lini { font-family: var(--lini-font-family); font-size: 14px; color: var(--lini-text-color); }
    .lini .lini-shape-box { fill: var(--lini-fill); stroke: var(--lini-stroke); stroke-width: 1; stroke-dasharray: none; }
    .lini .lini-text { fill: currentColor; stroke: none; text-anchor: middle; dominant-baseline: central; }
  </style>
  <defs/>
  <g class="lini-scene">
    <g class="lini-node lini-shape-box" transform="translate(0,0)">
      <rect x="-35.25" y="-23" width="70.5" height="46" rx="0" ry="0"/>
      <text class="lini-text" x="0" y="0">hello</text>
    </g>
  </g>
  <g class="lini-wires"/>
</svg>
